{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "app2: Nuxt dev - localhost API",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"],
      "cwd": "${workspaceFolder}",
      "env": {
        "NUXT_PUBLIC_API_BASE": "/api",
        "NUXT_API_PROXY_TARGET": "http://localhost:8000"
      },
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "app2: Nuxt dev - localhost API (public app tunnel)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"],
      "cwd": "${workspaceFolder}",
      "env": {
        "NUXT_PUBLIC_API_BASE": "/api",
        "NUXT_API_PROXY_TARGET": "http://localhost:8000"
      },
      "console": "integratedTerminal"
    }
  ]
}
