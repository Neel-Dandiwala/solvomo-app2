# Same-origin API path. Nitro proxies this to NUXT_API_PROXY_TARGET.
NUXT_PUBLIC_API_BASE=/api
NUXT_API_PROXY_TARGET=http://localhost:8000

# Required by nuxt-auth-utils when its encrypted session helpers are used.
# Use a 32+ character random value in real environments.
NUXT_SESSION_PASSWORD=change-me-to-a-very-long-random-session-secret
